enum PermissionEffect {
  ALLOW // Kullanıcıya bu yetki açıkça verildi
  DENY  // Kullanıcı için bu yetki açıkça engellendi
}

model Permission {
  id String @id @default(cuid()) // Yetki benzersiz id'si

  code String @unique // Sistem içinde kullanılan benzersiz yetki kodu: supplier.read, user.create vb.
  name String // Kullanıcıya gösterilecek yetki adı

  description String? // Yetkinin açıklaması

  userPermissions UserPermission[] // Bu yetkiye sahip kullanıcı-yetki ilişkileri

  createdAt DateTime @default(now()) // Yetki oluşturulma tarihi
  updatedAt DateTime @updatedAt // Yetki son güncellenme tarihi
}

model UserPermission {
  id String @id @default(cuid()) // Kullanıcı-yetki ilişki id'si

  userId String // Yetki verilen kullanıcı id'si
  permissionId String // Verilen yetki id'si

  effect PermissionEffect @default(ALLOW) // Yetki etkisi: ALLOW verilmiş yetki, DENY engellenmiş yetki

  user User @relation(fields: [userId], references: [id], onDelete: Cascade) // Yetki verilen kullanıcı
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade) // Kullanıcıya verilen yetki

  createdAt DateTime @default(now()) // Yetki atanma tarihi
  updatedAt DateTime @updatedAt // Yetki ilişkisi son güncellenme tarihi

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([effect])
}