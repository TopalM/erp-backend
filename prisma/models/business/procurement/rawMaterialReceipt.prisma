enum RawMaterialReceiptStatus {
  DRAFT
  RECEIVED
  QC_PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model RawMaterialReceipt {
  id String @id @default(cuid())

  supplierId      String
  purchaseOrderId String?

  receiptNo String @unique

  receiptDate DateTime @db.Date

  supplierBatchNo String?
  documentNo      String?

  status RawMaterialReceiptStatus @default(RECEIVED)

  note String?

  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  items RawMaterialReceiptItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([receiptDate])
  @@index([status])
  @@index([deletedAt])
}

model RawMaterialReceiptItem {
  id String @id @default(cuid())

  receiptId String

  rawMaterialId String
  productId     String?

  quantity Decimal @db.Decimal(18, 4)

  unitId String?
  unit   Unit? @relation("RawMaterialReceiptItemUnit", fields: [unitId], references: [id], onDelete: SetNull)

  lotNo String?

  receipt     RawMaterialReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial        @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  product     Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)

  productionInputs ProductionInput[]

  createdAt DateTime @default(now())

  @@index([unitId])
  @@index([receiptId])
  @@index([rawMaterialId])
  @@index([productId])
  @@index([lotNo])
}