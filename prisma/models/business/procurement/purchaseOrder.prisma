enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  SENT_TO_IMPORT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseOrderType {
  DOMESTIC
  IMPORT
}

enum PurchaseCategory {
  RAW_MATERIAL
  PACKAGING
  MATERIAL
  TRADE_PRODUCT
  SERVICE
  TRANSPORT
}

model PurchaseOrder {
  id String @id @default(cuid())

  supplierId String
  orderNo    String @unique

  orderDate    DateTime  @db.Date
  deliveryDate DateTime? @db.Date

  purchaseReasonId String?
  purchaseReason   PurchaseReason? @relation(fields: [purchaseReasonId], references: [id], onDelete: SetNull)

  placeOfUseId String?
  placeOfUse   PlaceOfUse? @relation(fields: [placeOfUseId], references: [id], onDelete: SetNull)

  purchasedTypeId String?
  purchasedType   Purchased? @relation(fields: [purchasedTypeId], references: [id], onDelete: SetNull)

  transportTypeId String?
  transportType   TransportType? @relation(fields: [transportTypeId], references: [id], onDelete: SetNull)

  paymentTermId String?
  paymentTerm   PaymentTerm? @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)

  deliveryDay Int?

  status    PurchaseOrderStatus @default(DRAFT)
  orderType PurchaseOrderType   @default(DOMESTIC)

  currencyId String?
  currency   Currency? @relation("PurchaseOrderCurrency", fields: [currencyId], references: [id], onDelete: SetNull)

  totalWithoutTax Decimal? @db.Decimal(18, 2)
  totalTax        Decimal? @db.Decimal(18, 2)
  totalWithTax    Decimal? @db.Decimal(18, 2)

  isDifferentVat Boolean @default(false)

  isStopaj    Boolean  @default(false)
  stopajRatio Decimal? @db.Decimal(8, 2)
  totalStopaj Decimal? @db.Decimal(18, 2)

  isTevkifat    Boolean  @default(false)
  tevkifatRatio Decimal? @db.Decimal(8, 2)
  totalTevkifat Decimal? @db.Decimal(18, 2)

  isInsurance Boolean @default(false)

  supplierPointId String?
  supplierPoint   SupplierPoint? @relation(fields: [supplierPointId], references: [id], onDelete: SetNull)

  purchaseRequestId String?
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)

  description String?
  note        String?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  items    PurchaseOrderItem[]
  receipts RawMaterialReceipt[]

  createdById String?
  createdBy   User? @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([purchaseRequestId])
  @@index([supplierId])
  @@index([orderDate])
  @@index([purchaseReasonId])
  @@index([placeOfUseId])
  @@index([purchasedTypeId])
  @@index([transportTypeId])
  @@index([paymentTermId])
  @@index([currencyId])
  @@index([supplierPointId])
  @@index([status])
  @@index([orderType])
  @@index([createdById])
  @@index([deletedAt])
}

model PurchaseOrderItem {
  id String @id @default(cuid())

  purchaseOrderId String

  category PurchaseCategory @default(MATERIAL)

  rawMaterialId String?
  productId     String?
  priceRecordId String?

  serviceName  String?
  materialName String?
  description  String?

  quantity Decimal @db.Decimal(18, 4)

  unitId String?
  unit   Unit? @relation("PurchaseOrderItemUnit", fields: [unitId], references: [id], onDelete: SetNull)

  unitPrice Decimal @db.Decimal(18, 4)

  currencyId String?
  currency   Currency? @relation("PurchaseOrderItemCurrency", fields: [currencyId], references: [id], onDelete: SetNull)

  taxRatioId String?
  taxRatio   TaxRatio? @relation("PurchaseOrderItemTaxRatio", fields: [taxRatioId], references: [id], onDelete: SetNull)

  differentVatRatioId String?
  differentVatRatio   TaxRatio? @relation("PurchaseOrderItemDifferentVatRatio", fields: [differentVatRatioId], references: [id], onDelete: SetNull)

  totalWithoutTax Decimal? @db.Decimal(18, 2)
  taxAmount       Decimal? @db.Decimal(18, 2)
  totalWithTax    Decimal? @db.Decimal(18, 2)

  note String?

  purchaseOrder PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial?            @relation(fields: [rawMaterialId], references: [id], onDelete: SetNull)
  product       Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)
  priceRecord   RawMaterialPriceRecord? @relation(fields: [priceRecordId], references: [id], onDelete: SetNull)

  purchaseRequestItemId String?
  purchaseRequestItem   PurchaseRequestItem? @relation(fields: [purchaseRequestItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([purchaseRequestItemId])
  @@index([category])
  @@index([rawMaterialId])
  @@index([productId])
  @@index([priceRecordId])
  @@index([unitId])
  @@index([currencyId])
  @@index([taxRatioId])
  @@index([differentVatRatioId])
}