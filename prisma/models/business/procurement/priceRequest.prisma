enum PriceRequestSupplierStatus {
  DRAFT
  READY
  SENT
  FAILED
  RESPONDED
  EXPIRED
}

enum PriceRecordSource {
  MANUAL
  MAIL
}

enum PurchaseMessageLanguage {
  TR
  EN
}

model RawMaterial {
  id String @id @default(cuid())

  code String @unique
  name String @unique

  isActive Boolean @default(true)

  supplierRawMaterials SupplierRawMaterial[]

  receiptItems RawMaterialReceiptItem[]

  priceRecords  RawMaterialPriceRecord[]
  priceRequests RawMaterialPriceRequest[]

  purchaseOrderItems PurchaseOrderItem[]

  purchaseRequestItems PurchaseRequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

model RawMaterialPriceRecord {
  id String @id @default(cuid())

  supplierId String

  rawMaterialId String
  productId     String?

  priceRequestSupplierId String?

  price         Decimal  @db.Decimal(18, 4)
  previousPrice Decimal? @db.Decimal(18, 4)

  currencyId String?
  currency   Currency? @relation(fields: [currencyId], references: [id], onDelete: SetNull)

  unitId String?
  unit   Unit? @relation("RawMaterialPriceRecordUnit", fields: [unitId], references: [id], onDelete: SetNull)

  priceDate  DateTime  @db.Date
  validUntil DateTime? @db.Date

  source PriceRecordSource @default(MANUAL)

  paymentTermId String?
  paymentTerm   PaymentTerm? @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)

  deliveryDay Int?

  note String?

  supplier    Supplier    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  priceRequestSupplier RawMaterialPriceRequestSupplier? @relation(fields: [priceRequestSupplierId], references: [id], onDelete: SetNull)

  purchaseOrderItems PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([supplierId])
  @@index([rawMaterialId])
  @@index([productId])
  @@index([priceRequestSupplierId])
  @@index([currencyId])
  @@index([priceDate])
  @@index([validUntil])
  @@index([source])
  @@index([paymentTermId])
  @@index([deliveryDay])
}

model RawMaterialPriceRequestDraft {
  id String @id @default(cuid())

  title   String
  subject String?
  message String

  language PurchaseMessageLanguage @default(EN)

  isActive Boolean @default(true)

  requests RawMaterialPriceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([language])
  @@index([isActive])
}

model RawMaterialPriceRequest {
  id String @id @default(cuid())

  draftId String?

  rawMaterialId String?
  productId     String?

  subject String?
  message String

  requestedAt DateTime @default(now())

  draft       RawMaterialPriceRequestDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)
  rawMaterial RawMaterial?                  @relation(fields: [rawMaterialId], references: [id], onDelete: SetNull)
  product     Product?                      @relation(fields: [productId], references: [id], onDelete: SetNull)

  suppliers RawMaterialPriceRequestSupplier[]

  createdAt DateTime @default(now())

  @@index([draftId])
  @@index([rawMaterialId])
  @@index([productId])
  @@index([requestedAt])
}

model RawMaterialPriceRequestSupplier {
  id String @id @default(cuid())

  requestId  String
  supplierId String
  contactId  String?

  status PriceRequestSupplierStatus @default(DRAFT)

  token          String?   @unique
  tokenExpiresAt DateTime?
  respondedAt    DateTime?

  sentAt DateTime?
  error  String?

  request  RawMaterialPriceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supplier Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  priceRecords RawMaterialPriceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requestId, supplierId])
  @@index([requestId])
  @@index([supplierId])
  @@index([contactId])
  @@index([status])
  @@index([token])
  @@index([tokenExpiresAt])
  @@index([respondedAt])
}

model RawMaterialPurchaseSettings {
  id String @id @default(cuid())

  enabled Boolean @default(true)

  messageLanguage PurchaseMessageLanguage @default(EN)

  defaultCountryCode String @default("90")

  mailSubjectTr String?
  mailSubjectEn String?

  messageTr String
  messageEn String

  addProductName  Boolean @default(true)
  addPaymentTerm  Boolean @default(true)
  addDeliveryTerm Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}