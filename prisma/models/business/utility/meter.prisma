model UtilityMeter {
  id String @id @default(cuid())

  code String @unique
  name String

  meterTypeId String
  meterType   UtilityMeterType @relation(fields: [meterTypeId], references: [id], onDelete: Restrict)

  unit String

  isActive Boolean @default(true)

  readings UtilityMeterReading[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([meterTypeId])
  @@index([isActive])
  @@map("utility_meters")
}