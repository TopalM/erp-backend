enum MaintenanceType {
  FAULT
  PERIODIC
}

enum MaintenanceStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

model Maintenance {
  id Int @id @default(autoincrement())

  type MaintenanceType

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  mainEquipmentId Int
  mainEquipment   Equipment @relation("MaintenanceMainEquipment", fields: [mainEquipmentId], references: [id])

  subEquipmentId Int?
  subEquipment   Equipment? @relation("MaintenanceSubEquipment", fields: [subEquipmentId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  status MaintenanceStatus @default(OPEN)

  requester String?
  savedBy   String?
  revisedBy String?

  revisedDate DateTime @default(now())

  description          String
  endOfWorkDescription String?

  faultTypeId String?
  faultType   FaultType? @relation(fields: [faultTypeId], references: [id], onDelete: SetNull)

  reasonFailureId String?
  reasonFailure   FailureReason? @relation(fields: [reasonFailureId], references: [id], onDelete: SetNull)

  workStartDateTime DateTime?
  workEndDateTime   DateTime?

  invoiceDate  DateTime?
  invoicePrice Decimal? @db.Decimal(18, 2)

  currencyId String?
  currency   Currency? @relation(fields: [currencyId], references: [id], onDelete: SetNull)

  firstPeriodicMaintenanceDate DateTime?
  annualPlanned                String?
  whichMaintenance             Int?

  totalPriceWithMaterialAndWorking Decimal? @db.Decimal(18, 2)

  rejectReason String?

  workers   MaintenanceWorker[]
  materials MaintenanceMaterial[]
  schedules MaintenanceSchedule[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type])
  @@index([locationId])
  @@index([mainEquipmentId])
  @@index([subEquipmentId])
  @@index([supplierId])
  @@index([faultTypeId])
  @@index([reasonFailureId])
  @@index([currencyId])
  @@index([status])
  @@index([deletedAt])
  @@map("maintenances")
}

model MaintenanceWorker {
  id Int @id @default(autoincrement())

  maintenanceId Int
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  workDescription String?
  workMinute      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([maintenanceId, employeeId])
  @@index([maintenanceId])
  @@index([employeeId])
  @@map("maintenance_workers")
}

model MaintenanceMaterial {
  id Int @id @default(autoincrement())

  maintenanceId Int
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  materialName String

  quantity Decimal? @db.Decimal(18, 4)
  unit     String?

  unitPrice Decimal? @db.Decimal(18, 4)

  currencyId String?
  currency   Currency? @relation(fields: [currencyId], references: [id], onDelete: SetNull)

  totalPrice Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([maintenanceId])
  @@index([materialName])
  @@index([currencyId])
  @@map("maintenance_materials")
}

model MaintenanceSchedule {
  id Int @id @default(autoincrement())

  maintenanceId Int
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  plannedDate DateTime
  actualDate  DateTime?

  status MaintenanceStatus @default(OPEN)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([maintenanceId])
  @@index([plannedDate])
  @@index([actualDate])
  @@index([status])
  @@map("maintenance_schedules")
}