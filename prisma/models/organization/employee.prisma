enum EmployeeStatus {
  ACTIVE
  PASSIVE
  RESIGNED
  TERMINATED
}

enum EmployeeType {
  BLUE_COLLAR
  WHITE_COLLAR
}

model Employee {
  id String @id @default(cuid())

  employeeCode String @unique
  firstName    String
  lastName     String

  type   EmployeeType   @default(BLUE_COLLAR)
  status EmployeeStatus @default(ACTIVE)

  phone String?
  email String?

  identityNumber String?   @unique
  birthDate      DateTime?

  hireDate  DateTime?
  leaveDate DateTime?

  title String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  bloodTypeId Int?
  bloodType   BloodType? @relation(fields: [bloodTypeId], references: [id], onDelete: SetNull)

  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  cityId Int?
  city   City? @relation(fields: [cityId], references: [id], onDelete: SetNull)

  districtId Int?
  district   District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  address String?

  monthlySalary  Decimal? @db.Decimal(12, 2)
  salaryCurrency String?  @default("TRY")

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeCode])
  @@index([firstName])
  @@index([lastName])
  @@index([status])
  @@index([type])
  @@index([departmentId])
  @@index([userId])
  @@index([bloodTypeId])
  @@index([locationId])
  @@index([cityId])
  @@index([districtId])
  @@map("Employee")
}