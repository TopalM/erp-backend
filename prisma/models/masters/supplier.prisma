enum SupplierCategoryType {
  RAW_MATERIAL
  PACKAGING
  MATERIAL
  TRADE_PRODUCT
  SERVICE
  TRANSPORT
}

enum SupplierEvaluationType {
  PURCHASING_QUALITY
  DELIVERY_TIME
  DELIVERY_QUANTITY
  PAYMENT_TERMS

  SERVICE_QUALITY
  SCHEDULE_ADHERENCE
  PROBLEM_SOLVING

  RAW_MATERIAL_QUALITY
  COA_COMPLIANCE
  QC_COMPLIANCE
  LOT_TRACEABILITY
  PACKAGING_CONDITION
}

enum SupplierEvaluationSource {
  PURCHASING
  QUALITY
}

model Supplier {
  id String @id @default(cuid()) // Tedarikçi benzersiz id'si

  // TEMEL FİRMA BİLGİLERİ

  name String // Firma adı

  phone String // Firma telefon numarası
  email String // Firma e-posta adresi

  address String // Açık adres bilgisi

  countryId Int?
  country   Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  cityId Int?
  city   City? @relation(fields: [cityId], references: [id], onDelete: SetNull)

  districtId Int?
  district   District? @relation(fields: [districtId], references: [id], onDelete: SetNull)

  taxOfficeId String?
  taxOffice   TaxOffice? @relation(fields: [taxOfficeId], references: [id], onDelete: SetNull)

  taxNumber String? // Vergi numarası

  // BELGE / ISO DURUM ALANLARI

  isDocumentNone Boolean @default(false) // Tedarikçi belge sunmadı / belgesi yok olarak işaretlendi mi?
  documentRequestEnabled Boolean @default(false) // Tedarikçiye belge talep maili gönderilecek mi?

  iso9001 Boolean @default(false) // ISO 9001 belgesi var mı?
  iso14001 Boolean @default(false) // ISO 14001 belgesi var mı?
  iso45001 Boolean @default(false) // ISO 45001 belgesi var mı?
  iso50001 Boolean @default(false) // ISO 50001 belgesi var mı?

  // İLETİŞİM BİLGİLERİ

  contactName String // Firma içerisindeki birincil iletişim kişisi
  contactPhone String? // İletişim kişisinin telefon numarası
  contactEmail String? // İletişim kişisinin e-posta adresi

  // EK BİLGİLER

  notes String? // Tedarikçi hakkında genel notlar
  risk String? // Risk değerlendirme notu

  isActive Boolean @default(true) // Tedarikçi aktif mi?
  isFavorite Boolean @default(false) // Favori tedarikçi mi?

  // MALZEME / AMBALAJ TEDARİKÇİ DEĞERLENDİRMELERİ

  purchasingQualityAverageScore Decimal? @db.Decimal(8, 2) // Satın alınan malzemenin kalite performansı ortalama puanı
  deliveryTimeAverageScore Decimal? @db.Decimal(8, 2) // Teslimat terminine uyum ortalama puanı
  deliveryQuantityAverageScore Decimal? @db.Decimal(8, 2) // Teslim edilen miktarın sipariş miktarına uygunluk ortalama puanı
  paymentTermsAverageScore Decimal? @db.Decimal(8, 2) // Ödeme şartları ve ticari koşullar ortalama puanı

  // HİZMET TEDARİKÇİ DEĞERLENDİRMELERİ

  serviceQualityAverageScore Decimal? @db.Decimal(8, 2) // Verilen hizmetin kalite performansı ortalama puanı
  scheduleAdherenceAverageScore Decimal? @db.Decimal(8, 2) // İş planına ve terminlere uyum ortalama puanı
  problemSolvingAverageScore Decimal? @db.Decimal(8, 2) // Problem çözme ve aksiyon alma kabiliyeti ortalama puanı

  // HAMMADDE TEDARİKÇİ DEĞERLENDİRMELERİ

  rawMaterialQualityAverageScore Decimal? @db.Decimal(8, 2) // Gelen hammaddenin kalite performansı ortalama puanı
  coaComplianceAverageScore Decimal? @db.Decimal(8, 2) // Analiz sertifikası (COA) uygunluk ortalama puanı
  qcComplianceAverageScore Decimal? @db.Decimal(8, 2) // Giriş kalite kontrol sonuçlarının uygunluk ortalama puanı
  lotTraceabilityAverageScore Decimal? @db.Decimal(8, 2) // Lot ve izlenebilirlik bilgilerinin uygunluk ortalama puanı
  packagingConditionAverageScore Decimal? @db.Decimal(8, 2) // Ambalaj ve sevkiyat kondisyonu ortalama puanı

  // GENEL TEDARİKÇİ PERFORMANSI

  overallAverageScore Decimal? @db.Decimal(8, 2) // Tüm değerlendirme kriterlerinden hesaplanan genel performans puanı

  // TEDARİKÇİ İLİŞKİLERİ

  categories SupplierCategory[] // Tedarikçi kategorileri
  documents SupplierDocument[] // Tedarikçi belgeleri
  evaluations SupplierEvaluation[] // Tedarikçi değerlendirme kayıtları

  // TEDARİK EDİLEN ÜRÜNLER

  rawMaterials SupplierRawMaterial[] // Tedarikçinin sağlayabildiği ürün ve hammaddeler

  // FİYAT YÖNETİMİ

  priceRecords RawMaterialPriceRecord[] // Hammadde fiyat geçmişi
  priceRequests RawMaterialPriceRequestSupplier[] // Fiyat talep süreçleri

  // SATINALMA VE KABUL SÜREÇLERİ

  purchaseOrders PurchaseOrder[] // Satınalma siparişleri
  rawMaterialReceipts RawMaterialReceipt[] // Hammadde kabul kayıtları

  // BAKIM VE SERVİS SÜREÇLERİ

  maintenances Maintenance[]

  // AUDIT ALANLARI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  createdById String
  updatedById String?
  deletedById String?

  createdBy User @relation("SupplierCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User? @relation("SupplierUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy User? @relation("SupplierDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])

  @@index([countryId])
  @@index([cityId])
  @@index([districtId])
  @@index([taxOfficeId])
}

model SupplierCategory {
  id              String @id @default(cuid()) // Tedarikçi kategori kaydı id'si

  supplierId      String // Kategorinin bağlı olduğu tedarikçi id'si
  type            SupplierCategoryType // Tedarikçi kategorisi: RAW_MATERIAL, PACKAGING, MATERIAL, TRADE_PRODUCT, SERVICE, TRANSPORT

  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade) // Bağlı tedarikçi

  createdAt       DateTime @default(now()) // Kategori eklenme tarihi

  @@unique([supplierId, type])
  @@index([type])
}

model SupplierRawMaterial {
  id String @id @default(cuid())

  supplierId    String
  rawMaterialId String

  supplier    Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([supplierId, rawMaterialId])
  @@index([supplierId])
  @@index([rawMaterialId])
}


model SupplierDocumentType {
  id              String @id @default(cuid()) // Belge tipi benzersiz kayıt id'si

  code            String @unique // Belge tipi kodu: ISO9001, ISO14001, ISO45001, ISO50001, SDS, TDS, COA vb.
  name            String @unique // Kullanıcıya gösterilecek belge tipi adı
  description     String? // Belge tipiyle ilgili açıklama

  isActive        Boolean @default(true) // Belge tipi aktif mi?

  documents       SupplierDocument[] // Bu belge tipine bağlı tedarikçi belge kayıtları

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SupplierDocument {
  id String @id @default(cuid())

  supplierId     String
  documentTypeId String

  isRequested Boolean @default(false)
  requestedAt DateTime?

  expiryDate DateTime?
  notes      String?

  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  documentType SupplierDocumentType @relation(fields: [documentTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, documentTypeId])
  @@index([supplierId])
  @@index([documentTypeId])
  @@index([expiryDate])
}

model SupplierEvaluation {
  id String @id @default(cuid()) // Tedarikçi değerlendirme kaydı benzersiz id'si

  supplierId String // Değerlendirilen tedarikçi id'si

  purchaseOrderId String? // Değerlendirmenin bağlı olduğu satınalma siparişi
  rawMaterialReceiptId String? // Değerlendirmenin bağlı olduğu hammadde kabul kaydı
  qualityInspectionId String? // Değerlendirmenin bağlı olduğu kalite kontrol kaydı

  evaluationType SupplierEvaluationType // Değerlendirme kriteri (Kalite, Termin, Evrak vb.)
  source SupplierEvaluationSource // Değerlendirmeyi yapan birim (Satınalma, Kalite vb.)

  score Decimal @db.Decimal(8, 2) // Verilen puan (0-100 arası)
  comment String? // Değerlendirme notu ve açıklaması

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade) // Değerlendirilen tedarikçi

  createdById String? 
  createdBy User? @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([rawMaterialReceiptId])
  @@index([qualityInspectionId])
  @@index([evaluationType])
  @@index([source])
  @@index([createdAt])
}