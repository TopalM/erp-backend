model Unit {
  id String @id @default(cuid())

  code   String @unique
  name   String @unique
  symbol String?

  isActive Boolean @default(true)

  rawMaterialPriceRecords RawMaterialPriceRecord[] @relation("RawMaterialPriceRecordUnit")
  purchaseRequestItems    PurchaseRequestItem[]    @relation("PurchaseRequestItemUnit")
  purchaseOrderItems      PurchaseOrderItem[]      @relation("PurchaseOrderItemUnit")
  rawMaterialReceiptItems RawMaterialReceiptItem[] @relation("RawMaterialReceiptItemUnit")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@index([isActive])
  @@map("units")
}