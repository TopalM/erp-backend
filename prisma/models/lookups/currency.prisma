model Currency {
  id String @id @default(cuid())

  legacyId Int? @unique
  code     String @unique
  name     String?

  isActive Boolean @default(true)

  equipments           Equipment[]
  maintenances         Maintenance[]
  maintenanceMaterials MaintenanceMaterial[]

  rawMaterialPriceRecords RawMaterialPriceRecord[]
  
  purchaseRequestItems PurchaseRequestItem[] @relation("PurchaseRequestItemCurrency")

  purchaseOrders     PurchaseOrder[]     @relation("PurchaseOrderCurrency")
  purchaseOrderItems PurchaseOrderItem[] @relation("PurchaseOrderItemCurrency")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}