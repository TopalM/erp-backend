enum PaymentTermScope {
  GENERAL
  RAW_MATERIAL
}

model PaymentTerm {
  id            Int @id

  scope         PaymentTermScope @default(GENERAL)

  code          String?
  name          String
  days          Int?

  requiresDay   Boolean @default(false)

  isActive      Boolean @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([scope, name])
  @@index([scope])
  @@index([isActive])
  @@map("Lookup_PaymentTerm")
}