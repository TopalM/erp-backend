model UtilityMeterType {
  id String @id @default(cuid())

  legacyId Int? @unique

  code String @unique
  name String @unique

  defaultUnit String?

  isActive Boolean @default(true)

  meters UtilityMeter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("utility_meter_types")
}