model TaxOffice {
  id     Int @id

  cityId Int

  name String

  city City @relation(fields: [cityId], references: [id], onDelete: Restrict)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, name])
  @@index([cityId])
  @@map("Lookup_TaxOffice")
}