model TaxOffice {
  id String @id @default(cuid())

  legacyId Int? @unique

  cityId Int

  name String

  city City @relation(fields: [cityId], references: [id], onDelete: Restrict)

  suppliers Supplier[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, name])

  @@index([cityId])
}