model TaxRatio {
  id        String @id @default(cuid())

  legacyId  Int? @unique
  value     Decimal @unique @db.Decimal(5, 2)
  name      String

  purchaseOrderItemsTaxRatio         PurchaseOrderItem[] @relation("PurchaseOrderItemTaxRatio")
  purchaseOrderItemsDifferentVatRatio PurchaseOrderItem[] @relation("PurchaseOrderItemDifferentVatRatio")

  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}