model SubRegion {
  id          Int @id

  countryId   Int

  country     Country @relation(fields: [countryId], references: [id])

  name        String

  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([countryId, name])
  @@index([countryId])
  @@map("Lookup_SubRegion")
}