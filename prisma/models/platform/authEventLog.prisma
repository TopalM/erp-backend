enum AuthEventType {
  REGISTER_SUCCESS

  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT

  ACCOUNT_LOCKED

  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_CHANGED

  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFICATION_FAILED
  EMAIL_VERIFIED
}

model AuthEventLog {
  id            String @id @default(cuid())

  userId        String?
  email         String?

  event         AuthEventType

  ipAddress     String?
  userAgent     String?

  success       Boolean @default(false)

  message       String?

  createdAt     DateTime @default(now())

  user          User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([event])
  @@index([createdAt])
  @@map("AuthEventLog")
}