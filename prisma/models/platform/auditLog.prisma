enum AuditModule {
  AUTH
  USER
  ROLE
  PERMISSION
  SUPPLIER
  PRODUCT
  PURCHASE
  RAW_MATERIAL_RECEIPT
  QUALITY
  MAINTENANCE
  PRODUCTION
  STORAGE
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE

  LOGIN
  LOGOUT

  APPROVE
  REJECT

  UPLOAD
  DOWNLOAD

  USER_ACTIVATED
  USER_DEACTIVATED
  USER_ROLE_UPDATED
  USER_DEPARTMENT_UPDATED
  USER_FORCE_LOGOUT

  ERROR
}

model AuditLog {
  id              String @id @default(cuid())

  actorUserId     String?
  actorEmail      String?

  entityType      AuditModule
  entityId        String?

  action          AuditAction

  message         String?

  oldValue        Json?
  newValue        Json?

  ipAddress       String?
  userAgent       String?

  createdAt       DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("AuditLog")
}