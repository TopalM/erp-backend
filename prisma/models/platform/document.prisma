enum DocumentModule {
  PURCHASING
  SUPPLIER
  QUALITY
  PRODUCTION
  SHIPMENT
  MAINTENANCE
  EMPLOYEE
  ACCOUNTING
  UTILITY
  SYSTEM
}

enum DocumentEntityType {
  PURCHASE_REQUEST
  PURCHASE_QUOTATION
  PURCHASE_ORDER
  PURCHASE_RECEIPT
  VENDOR_INVOICE

  SUPPLIER
  SUPPLIER_DOCUMENT

  QUALITY_INSPECTION
  QUALITY_CERTIFICATE
  QUALITY_DEVIATION

  PRODUCTION_ORDER
  PRODUCTION_BATCH

  SHIPMENT_PLAN
  DISPATCH_NOTE

  MAINTENANCE
  EQUIPMENT

  EMPLOYEE

  UTILITY_READING

  OTHER
}

enum DocumentType {
  QUOTATION
  PURCHASE_FORM
  DELIVERY_NOTE
  RECEIPT_DOCUMENT
  INVOICE

  ISO_9001
  ISO_14001
  ISO_45001
  ISO_50001

  COA
  SDS
  TDS
  ANALYSIS_REPORT

  PACKING_LIST

  MAINTENANCE_FORM
  EMPLOYEE_DOCUMENT

  UTILITY_REPORT

  OTHER
}

model Document {
  id String @id @default(cuid())

  module     DocumentModule
  entityType DocumentEntityType
  entityId   String

  documentType DocumentType @default(OTHER)

  title       String?
  description String?

  originalFileName String
  storedFileName   String
  filePath         String

  mimeType      String?
  fileExtension String?
  sizeBytes     Int?

  storageProvider String?

  uploadedById String?
  uploadedBy   User? @relation("UserUploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
  @@index([entityType, entityId])
  @@index([documentType])
  @@index([uploadedById])
  @@index([isActive])

  @@map("Document")
}