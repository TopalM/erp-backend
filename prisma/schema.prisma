// ---- platform/auditLog.prisma ----
enum AuditModule {
  AUTH                            // Kimlik doğrulama işlemleri
  USER                            // Kullanıcı işlemleri
  ROLE                            // Rol işlemleri
  PERMISSION                      // Yetki işlemleri
  SUPPLIER                        // Tedarikçi işlemleri
  PRODUCT                         // Ürün işlemleri
  PURCHASE                        // Satınalma işlemleri
  RAW_MATERIAL_RECEIPT            // Hammadde kabul işlemleri
  QUALITY                         // Kalite işlemleri
  MAINTENANCE                     // Bakım işlemleri
  PRODUCTION                      // Üretim işlemleri
  STORAGE                         // Dosya depolama işlemleri
  SYSTEM                          // Sistem işlemleri
}

enum AuditAction {
  CREATE                          // Yeni kayıt oluşturma
  UPDATE                          // Kayıt güncelleme
  DELETE                          // Kayıt silme
  RESTORE                         // Silinen kaydı geri alma

  LOGIN                           // Sisteme giriş
  LOGOUT                          // Sistemden çıkış

  APPROVE                         // Onay verme
  REJECT                          // Reddetme

  UPLOAD                          // Dosya yükleme
  DOWNLOAD                        // Dosya indirme

  USER_ACTIVATED                  // Kullanıcı aktif edildi
  USER_DEACTIVATED                // Kullanıcı pasif edildi
  USER_ROLE_UPDATED               // Kullanıcı rolü güncellendi
  USER_DEPARTMENT_UPDATED         // Kullanıcı departmanı güncellendi
  USER_FORCE_LOGOUT               // Kullanıcının oturumları sonlandırıldı

  ERROR                           // Hata oluşması
}

model AuditLog {
  id              String @id @default(cuid()) // Audit log benzersiz id'si

  actorUserId     String? // İşlemi yapan kullanıcı id'si
  actorEmail      String? // İşlemi yapan kullanıcı e-postası

  entityType      AuditModule // İşlem yapılan modül
  entityId        String? // İşlem yapılan kayıt id'si

  action          AuditAction // Yapılan işlem

  message         String? // İşlem açıklaması

  oldValue        Json? // Değişiklik öncesi veri
  newValue        Json? // Değişiklik sonrası veri

  ipAddress       String? // İşlemin yapıldığı IP adresi
  userAgent       String? // Tarayıcı / cihaz bilgisi

  createdAt       DateTime @default(now()) // Log oluşturulma tarihi

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

// ---- platform/authEventLog.prisma ----
enum AuthEventType {
  REGISTER_SUCCESS              // Kullanıcı başarıyla kayıt oldu

  LOGIN_SUCCESS                 // Başarılı giriş yapıldı
  LOGIN_FAILED                  // Başarısız giriş denemesi
  LOGOUT                        // Kullanıcı sistemden çıkış yaptı

  ACCOUNT_LOCKED                // Çok fazla başarısız giriş nedeniyle hesap kilitlendi

  PASSWORD_RESET_REQUESTED      // Şifre sıfırlama talebi oluşturuldu
  PASSWORD_RESET_COMPLETED      // Şifre sıfırlama işlemi tamamlandı
  PASSWORD_CHANGED              // Kullanıcı mevcut şifresini değiştirdi

  EMAIL_VERIFICATION_SENT       // E-posta doğrulama bağlantısı gönderildi
  EMAIL_VERIFICATION_FAILED     // Geçersiz veya süresi geçmiş doğrulama denemesi yapıldı
  EMAIL_VERIFIED                // E-posta başarıyla doğrulandı
}

model AuthEventLog {
  id            String @id @default(cuid()) // Auth log kaydı benzersiz id'si

  userId        String? // İşlemle ilişkili kullanıcı id'si
  email         String? // İşlem sırasında kullanılan e-posta adresi

  event         AuthEventType // Gerçekleşen kimlik doğrulama olayı

  ipAddress     String? // İşlemin yapıldığı IP adresi
  userAgent     String? // Tarayıcı, işletim sistemi ve cihaz bilgisi

  success       Boolean @default(false) // İşlem başarılı mı?

  message       String? // Hata mesajı veya açıklama

  createdAt     DateTime @default(now()) // Log oluşturulma tarihi

  user          User? @relation(fields: [userId], references: [id], onDelete: SetNull) // İşlemle ilişkili kullanıcı

  @@index([userId])
  @@index([email])
  @@index([event])
  @@index([createdAt])
}

