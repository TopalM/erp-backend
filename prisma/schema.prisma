enum ApprovalEntityType {
  PURCHASE_REQUEST
  PURCHASE_ORDER
  PURCHASE_INVOICE

  SUPPLIER
  SUPPLIER_DOCUMENT

  QUALITY_INSPECTION
  QUALITY_DEVIATION
  QUALITY_CERTIFICATE

